{
    "info": {
        "name": "Testimonials API",
        "description": "API collection for managing testimonials",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "_exporter_id": "testimonials-api"
    },
    "item": [
        {
            "name": "Get Testimonials",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/testimonials",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "testimonials"
                    ]
                },
                "description": "Retrieve a paginated list of visible testimonials ordered by sort order."
            },
            "response": [
                {
                    "name": "Success Response",
                    "originalRequest": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/testimonials",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "testimonials"
                            ]
                        }
                    },
                    "status": "OK",
                    "code": 200,
                    "_postman_previewlanguage": "json",
                    "header": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        }
                    ],
                    "cookie": [],
                    "body": "{\n    \"success\": true,\n    \"message\": \"Testimonials retrieved successfully\",\n    \"data\": {\n        \"testimonials\": {\n            \"current_page\": 1,\n            \"data\": [\n                {\n                    \"id\": 1,\n                    \"client_name\": \"John Doe\",\n                    \"client_position\": \"CEO\",\n                    \"client_company\": \"Tech Corp\",\n                    \"testimonial\": \"Great service and excellent quality!\",\n                    \"rating\": 5,\n                    \"image\": \"https://your-domain.com/storage/testimonials/john-doe-avatar.jpg\",\n                    \"is_visible\": true,\n                    \"sort_order\": 1,\n                    \"created_at\": \"2026-02-28T10:00:00.000000Z\",\n                    \"updated_at\": \"2026-02-28T10:00:00.000000Z\"\n                }\n            ],\n            \"first_page_url\": \"{{base_url}}/api/v1/testimonials?page=1\",\n            \"from\": 1,\n            \"last_page\": 1,\n            \"last_page_url\": \"{{base_url}}/api/v1/testimonials?page=1\",\n            \"next_page_url\": null,\n            \"path\": \"{{base_url}}/api/v1/testimonials\",\n            \"per_page\": 10,\n            \"prev_page_url\": null,\n            \"to\": 1,\n            \"total\": 1\n        }\n    }\n}"
                }
            ]
        },
        {
            "name": "Get Testimonials with Custom Pagination",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/testimonials?per_page=5",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "testimonials"
                    ],
                    "query": [
                        {
                            "key": "per_page",
                            "value": "5",
                            "description": "Number of testimonials per page"
                        }
                    ]
                },
                "description": "Retrieve testimonials with custom pagination (5 per page)."
            }
        }
    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "// Set base_url variable if not set",
                    "if (!pm.environment.get('base_url')) {",
                    "    pm.environment.set('base_url', 'http://localhost:8000');",
                    "}"
                ]
            }
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000",
            "type": "string",
            "description": "Base URL for the API"
        }
    ]
}
