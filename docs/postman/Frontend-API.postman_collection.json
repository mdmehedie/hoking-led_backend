{
  "info": {
    "name": "Honking LED - Frontend API (v1)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Locales - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/locales",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "locales"
          ]
        }
      }
    },
    {
      "name": "Locales - List (Bangla via lang)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/locales?lang=bd",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "locales"
          ],
          "query": [
            {
              "key": "lang",
              "value": "bd"
            }
          ]
        }
      }
    },
    {
      "name": "Products - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products"
          ]
        }
      }
    },
    {
      "name": "Products - List (Bangla via Accept-Language)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Accept-Language",
            "value": "bd"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    }
  ]
}
