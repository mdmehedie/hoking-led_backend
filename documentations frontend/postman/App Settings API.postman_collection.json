{
    "info": {
        "name": "App Settings API",
        "_postman_id": "unique-id",
        "description": "API for retrieving app settings",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Get App Settings",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/v1/app-settings?per_page=10",
                    "host": ["{{base_url}}"],
                    "path": ["v1", "app-settings"],
                    "query": [
                        {
                            "key": "per_page",
                            "value": "10",
                            "description": "Number of app settings per page (default: 10)"
                        }
                    ]
                },
                "description": "Retrieve a list of app settings with pagination"
            },
            "response": []
        },
        {
            "name": "Get App Setting by Column",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/v1/app-settings/{{app_setting_column}}",
                    "host": ["{{base_url}}"],
                    "path": ["v1", "app-settings", "{{app_setting_column}}"]
                },
                "description": "Retrieve a specific field value from app settings by column name"
            },
            "response": []
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000/api",
            "type": "string"
        },
        {
            "key": "app_setting_column",
            "value": "logo_light",
            "type": "string"
        }
    ]
}
