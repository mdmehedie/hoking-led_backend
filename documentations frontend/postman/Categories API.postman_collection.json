{
  "info": {
    "name": "Categories API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API collection for retrieving categories data from the Laravel backend."
  },
  "item": [
    {
      "name": "Get Categories",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/v1/categories",
          "host": ["{{base_url}}"],
          "path": ["v1", "categories"],
          "query": [
            {
              "key": "per_page",
              "value": "10",
              "description": "Optional: Number of items per page (default 10)"
            }
          ]
        },
        "description": "Retrieves a list of active categories ordered by name. Supports pagination with per_page parameter (default 10)."
      },
      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/categories",
              "host": ["{{base_url}}"],
              "path": ["v1", "categories"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "{\n  \"status\": true,\n  \"message\": \"Categories retrieved successfully\",\n  \"data\": {\n    \"categories\": [\n      {\n        \"id\": 1,\n        \"name\": \"Sample Category\",\n        \"slug\": \"sample-category\",\n        \"status\": true,\n        \"created_at\": \"2023-01-01T00:00:00.000000Z\",\n        \"updated_at\": \"2023-01-01T00:00:00.000000Z\"\n      }\n    ]\n  }\n}"
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    }
  ]
}
