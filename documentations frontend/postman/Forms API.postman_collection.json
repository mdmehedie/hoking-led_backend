{
  "info": {
    "name": "Forms API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API collection for submitting forms and handling form data from the Laravel backend."
  },
  "item": [
    {
      "name": "Get Forms List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/v1/forms",
          "host": ["{{base_url}}"],
          "path": ["v1", "forms"]
        },
        "description": "Retrieves all active forms with email notifications or lead storage enabled."
      },
      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/forms",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "forms"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "{\n  \"success\": true,\n  \"message\": \"Forms retrieved successfully\",\n  \"data\": {\n    \"forms\": [\n      {\n        \"id\": 1,\n        \"name\": \"Contact Form\",\n        \"fields\": [\n          {\n            \"type\": \"text\",\n            \"label\": \"Name\",\n            \"placeholder\": \"Enter your name\",\n            \"required\": true\n          },\n          {\n            \"type\": \"email\",\n            \"label\": \"Email\",\n            \"placeholder\": \"Enter your email\",\n            \"required\": true\n          }\n        ],\n        \"success_message\": \"Thank you for contacting us!\"\n      }\n    ]\n  }\n}"
        }
      ]
    },
    {
      "name": "Submit Form",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"message\": \"This is a test form submission\",\n  \"select_field\": \"option1\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/v1/forms/{{form_id}}/submit",
          "host": ["{{base_url}}"],
          "path": ["v1", "forms", "{{form_id}}", "submit"]
        },
        "description": "Submits form data to the specified form ID. The form processes the submission based on its settings (lead storage, email notifications)."
      },
      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"message\": \"This is a test form submission\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/forms/1/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "forms", "1", "submit"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "{\n  \"success\": true,\n  \"message\": \"Form submitted successfully\",\n  \"data\": {\n    \"message\": \"Thank you for your submission!\"\n  }\n}"
        },
